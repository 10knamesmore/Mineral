#!/bin/sh
# 推送前:clippy + test 全跑(把关再分享,和 CI 的门一致)。
# 测试用 cargo-nextest(需 `cargo install cargo-nextest`);doctest 另跑(nextest 不覆盖)。
set -e
echo "[pre-push] cargo clippy --workspace --all-targets -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings
echo "[pre-push] cargo nextest run --workspace (INSTA_UPDATE=no)"
INSTA_UPDATE=no cargo nextest run --workspace
echo "[pre-push] cargo test --workspace --doc"
cargo test --workspace --doc
